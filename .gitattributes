# Set default behavior to automatically normalize line endings
* text=auto

# Force files to use LF line endings on check-in
*.java text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.xml text eol=lf

# Denote binary files that should not be normalized
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
